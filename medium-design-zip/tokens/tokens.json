{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "source": "https://medium.com",
    "extractedAt": "2026-07-14",
    "tool": "dembrandt",
    "format": "W3C DTCG"
  },
  "color": {
    "$type": "color",
    "primary": {
      "$value": "#191919",
      "$description": "Primary interactive color — buttons, CTAs. Near-black.",
      "$extensions": { "confidence": "high", "role": "primary" }
    },
    "background": {
      "$value": "#ffffff",
      "$description": "Page background — always white.",
      "$extensions": { "confidence": "high", "role": "surface" }
    },
    "text": {
      "$value": "rgba(0, 0, 0, 0.8)",
      "$description": "Body text — soft black, not pure black.",
      "$extensions": { "confidence": "high", "role": "text" }
    },
    "neutral-dark": {
      "$value": "#242424",
      "$description": "Dark neutral — icons, headings, high-contrast UI elements.",
      "$extensions": { "confidence": "high", "usage": 26, "role": "neutral", "hover": "#2b2b2b" }
    },
    "neutral-mid": {
      "$value": "#6b6b6b",
      "$description": "Mid neutral — secondary text, metadata, captions.",
      "$extensions": { "confidence": "high", "usage": 22, "role": "neutral", "hover": "#808080" }
    },
    "black": {
      "$value": "#000000",
      "$description": "Pure black — used as hover target for primary button, manifest theme color.",
      "$extensions": { "confidence": "high", "usage": 10 }
    },
    "hover-dark": {
      "$value": "#101010",
      "$description": "Deep near-black — focus/hover state.",
      "$extensions": { "confidence": "medium", "usage": 1, "role": "hover" }
    },
    "accent-green": {
      "$value": "#1a8917",
      "$description": "Medium brand green — applause button, success states, highlights. Use sparingly.",
      "$extensions": { "lch": "lch(49.7% 69.89 136.81)", "oklch": "oklch(54.98% 0.174 142.51)" }
    },
    "accent-bg-secondary": {
      "$value": "#bbdbba",
      "$description": "Light green background — accent secondary surface.",
      "$extensions": { "cssVar": "--color-bg-accent-secondary", "lch": "lch(84.37% 21.05 142.74)" }
    },
    "accent-bg-tertiary": {
      "$value": "#d2e7d1",
      "$description": "Lighter green background — accent tertiary surface.",
      "$extensions": { "cssVar": "--color-bg-accent-tertiary", "lch": "lch(89.61% 13.78 142.69)" }
    },
    "on-primary": {
      "$value": "#ffffff",
      "$description": "Text/icon color on primary (dark) background.",
      "$extensions": { "role": "on-primary" }
    }
  },
  "typography": {
    "fontFamily": {
      "display": {
        "$value": "'gt-super', Georgia, Cambria, 'Times New Roman', Times, serif",
        "$description": "Display / headline serif font. Self-hosted."
      },
      "ui": {
        "$value": "'sohne', 'Helvetica Neue', Helvetica, Arial, sans-serif",
        "$description": "UI and body sans-serif font. Self-hosted."
      },
      "system": {
        "$value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif",
        "$description": "System fallback stack."
      }
    },
    "fontSize": {
      "display":    { "$value": "120px", "$description": "Hero / display heading (GT Super)" },
      "heading-3":  { "$value": "22px",  "$description": "H3 heading (Sohne)" },
      "ui-lg":      { "$value": "20px",  "$description": "Large UI text / CTA label" },
      "body-md":    { "$value": "16px",  "$description": "Default body / link text" },
      "body-sm":    { "$value": "14px",  "$description": "Small body / UI (most common)" },
      "body-xs":    { "$value": "13px",  "$description": "Extra small body / captions" }
    },
    "fontWeight": {
      "regular": { "$value": "400", "$description": "Only weight used — Medium does not use bold." }
    },
    "lineHeight": {
      "display":   { "$value": "0.83" },
      "heading-3": { "$value": "1.27" },
      "ui-lg":     { "$value": "1.40" },
      "body-sm":   { "$value": "1.43" },
      "body-xs":   { "$value": "1.54" }
    },
    "letterSpacing": {
      "display": { "$value": "-6.6px", "$description": "Tight tracking on display heading." }
    }
  },
  "spacing": {
    "$description": "8px base grid",
    "space-1": { "$value": "8px",  "$description": "Base unit — component padding" },
    "space-2": { "$value": "10px", "$description": "Compact spacing" },
    "space-3": { "$value": "24px", "$description": "Section gap" },
    "space-4": { "$value": "25px", "$description": "Section gap (variant)" },
    "space-5": { "$value": "48px", "$description": "Large section separation" },
    "space-6": { "$value": "75px", "$description": "Hero / page-level spacing" }
  },
  "borderRadius": {
    "pill":  { "$value": "9999px", "$description": "Full pill — all buttons" },
    "badge": { "$value": "2px",    "$description": "Near-square — topic tags" }
  },
  "border": {
    "button": {
      "$value": "1px solid {color.primary}",
      "$description": "Button border — same color as background (filled pill look)"
    },
    "divider": {
      "$value": "1px solid #242424",
      "$description": "Subtle section divider"
    }
  },
  "shadow": {
    "overlay": {
      "$value": "rgb(128, 128, 128) 0px 0px 5px 0px",
      "$description": "Soft diffuse shadow — used on modal/overlay elements only"
    }
  },
  "motion": {
    "duration": {
      "instant": { "$value": "0.001s", "$description": "Effectively instant — all interactive transitions" }
    },
    "easing": {
      "ease":   { "$value": "ease",   "$description": "Links — color shift on hover" },
      "linear": { "$value": "linear", "$description": "Buttons — background-color, color" }
    }
  }
}
